<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Mole Mine Rocks</title>
<style>
  :root{
    --bg:#000;
    --panel:#090909;
    --panel2:#121212;
    --white:#f2f2f2;
    --muted:#bcbcbc;
    --gold:#f0be3c;
    --green:#46d26e;
    --red:#d23c3c;
    --cyan:#50dcdc;
    --pink:#f064b4;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;min-height:100%;background:var(--bg);color:var(--white);font-family:"Courier New",monospace;image-rendering:pixelated;}
  body{background:#000;}
  body:before{content:"";position:fixed;inset:0;pointer-events:none;background:repeating-linear-gradient(0deg,rgba(255,255,255,.025) 0 1px,transparent 1px 4px);mix-blend-mode:screen;opacity:.6;}
  .wrap{max-width:1180px;margin:0 auto;padding:16px;}
  header{display:flex;gap:16px;align-items:center;border:3px solid var(--white);padding:12px;background:#050505;box-shadow:0 0 0 3px #000,0 0 0 6px #fff;}
  .logo{width:82px;height:82px;object-fit:contain;image-rendering:pixelated;border:2px solid #fff;background:#000;}
  h1,h2,h3,p{margin:0;}
  h1{font-size:28px;letter-spacing:2px;color:var(--gold);text-transform:uppercase;text-shadow:3px 3px #2a2a00;}
  .tag{font-size:14px;color:var(--muted);margin-top:6px;line-height:1.4;}
  nav{display:flex;gap:8px;flex-wrap:wrap;margin:18px 0;}
  button,.pixel-link{font-family:inherit;font-weight:bold;letter-spacing:1px;background:#000;color:#fff;border:3px solid #fff;padding:10px 14px;text-decoration:none;cursor:pointer;box-shadow:4px 4px 0 #303030;text-transform:uppercase;}
  button:hover,.pixel-link:hover{background:#fff;color:#000;}
  button:disabled{opacity:.45;cursor:not-allowed;}
  .page{display:none;border:3px solid #fff;background:#050505;padding:14px;min-height:620px;}
  .page.active{display:block;}
  .hero{display:grid;grid-template-columns:170px 1fr;gap:16px;align-items:center;margin-bottom:14px;}
  .hero img{width:160px;height:160px;object-fit:contain;image-rendering:pixelated;border:3px solid #fff;background:#000;}
  .hero h2{color:var(--gold);font-size:24px;margin-bottom:8px;}
  .hero p{line-height:1.5;color:#ddd;}
  .notice{border:2px dashed #fff;padding:10px;background:#000;margin:12px 0;color:#fff;line-height:1.45;}
  #gameCanvas{display:block;width:100%;max-width:1100px;height:auto;margin:0 auto;border:4px solid #fff;background:#000;image-rendering:pixelated;box-shadow:0 0 0 4px #000,0 0 0 7px #fff;}
  .underbar{display:flex;flex-wrap:wrap;gap:8px;align-items:center;justify-content:center;margin-top:14px;}
  .small{font-size:12px;color:#cfcfcf;line-height:1.5;}
  .grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:12px;}
  .card{border:3px solid #fff;background:#000;padding:12px;min-height:150px;}
  .card h3{color:var(--gold);font-size:17px;margin-bottom:8px;text-transform:uppercase;}
  .card p{font-size:13px;line-height:1.45;color:#ddd;}
  .pixelart{width:96px;height:96px;background:#0a0a0a;border:2px solid #fff;display:block;margin:0 0 10px 0;image-rendering:pixelated;}
  .wiki-section-title{margin:20px 0 12px;color:var(--cyan);font-size:22px;text-transform:uppercase;}
  .merch-box{max-width:720px;margin:36px auto;border:4px solid #fff;padding:24px;background:#000;text-align:center;}
  .merch-box h2{font-size:28px;color:var(--gold);margin-bottom:14px;}
  .merch-box p{line-height:1.6;margin-bottom:18px;}
  .kbd{border:1px solid #fff;padding:1px 5px;background:#111;color:#fff;}
  @media (max-width:700px){.hero{grid-template-columns:1fr}.hero img{width:120px;height:120px}.wrap{padding:10px}h1{font-size:22px}}
</style>
</head>
<body>
<div class="wrap">
  <header>
    <img class="logo" src="data:image/png;base64," alt="Mole Mine Rocks logo">
    <div>
      <h1>Mole Mine Rocks</h1>
      <p class="tag">Pixel mining, pets, market selling, house furniture, and a tiny mole with the original miner hat look.</p>
    </div>
  </header>

  <nav>
    <button id="navPlay">PLAY</button>
    <button id="navWiki">MOLE MINE WIKI</button>
    <button id="navMerch">MERCH PAGE</button>
  </nav>

  <section id="playPage" class="page active">
    <div id="startPanel" class="hero">
      <img src="data:image/png;base64," alt="Mole Mine Rocks logo">
      <div>
        <h2 id="startTitle">NEW GAME</h2>
        <p id="startText">Press New Game once. After that, Mole Mine Rocks saves into this browser's local data and will never ask for New Game again.</p>
        <div style="margin-top:14px"><button id="startGameBtn">NEW GAME</button></div>
      </div>
    </div>
    <canvas id="gameCanvas" width="1100" height="720" tabindex="0"></canvas>
    <div class="underbar">
      <button id="soundBtn">SOUND: ON</button>
      <button id="saveBtn">SAVE</button>
      <button id="homeBtn">TITLE</button>
    </div>
    <div class="notice small">
      Controls: click to move/interact/mine, <span class="kbd">WASD</span> or arrow keys to step, <span class="kbd">E</span> interact, <span class="kbd">Space</span> mine nearby, <span class="kbd">I</span> bag, <span class="kbd">M</span> market, <span class="kbd">Esc</span> close panels. Energy naturally recharges very slowly all the time and is capped at 300. Fish gives the most energy back.
    </div>
  </section>

  <section id="wikiPage" class="page">
    <div class="hero">
      <img src="data:image/png;base64," alt="Mole Mine Rocks logo">
      <div>
        <h2>Mole Mine Wiki</h2>
        <p>A simple black-background pixel wiki for pets, foods, furniture, mining, and the market.</p>
      </div>
    </div>
    <h2 class="wiki-section-title">Pets</h2>
    <div id="petWiki" class="grid"></div>
    <h2 class="wiki-section-title">Furniture</h2>
    <div id="furnitureWiki" class="grid"></div>
    <h2 class="wiki-section-title">Energy Foods</h2>
    <div id="foodWiki" class="grid"></div>
    <h2 class="wiki-section-title">Market Notes</h2>
    <div class="notice">The Market can sell ores, eggs, fish, worms, mushrooms, golden fish, and hatched pets. Horse Eggs are late-depth drops, and high-stat Horse pets are the most valuable sellable pets.</div>
  </section>

  <section id="merchPage" class="page">
    <div class="merch-box">
      <img class="logo" style="width:120px;height:120px;margin-bottom:12px" src="data:image/png;base64," alt="Mole Mine Rocks logo">
      <h2>Mole Mine Rocks Merch</h2>
      <p>Open the official Mole Mine Rocks merch shop.</p>
      <a class="pixel-link" href="https://www.etsy.com/shop/moleminerocks" target="_blank" rel="noopener noreferrer">OPEN ETSY SHOP</a>
    </div>
  </section>
</div>

<script>
(function(){
"use strict";

const SAVE_KEY = "moleMineRocksHtmlSave_v1";
const STARTED_KEY = "moleMineRocksHtmlStarted_v1";
const TILE = 32, MAP_W = 25, MAP_H = 17, PANEL_X = MAP_W*TILE, WIDTH = 1100, HEIGHT = 720;
const canvas = document.getElementById("gameCanvas");
const ctx = canvas.getContext("2d");
ctx.imageSmoothingEnabled = false;

const C = {
  WHITE:"rgb(240,240,240)", BLACK:"rgb(10,10,14)", GREY:"rgb(92,92,96)", DARK_GREY:"rgb(46,46,52)",
  STONE:"rgb(82,82,86)", WALL:"rgb(50,48,55)", GOLD:"rgb(240,190,60)", RED:"rgb(210,60,60)",
  GREEN:"rgb(70,210,110)", BLUE:"rgb(80,150,240)", PURPLE:"rgb(160,90,230)", CYAN:"rgb(80,220,220)",
  ORANGE:"rgb(245,130,55)", PINK:"rgb(240,100,180)", YELLOW:"rgb(238,207,50)", BROWN:"rgb(105,66,36)",
  WOOD:"rgb(150,94,48)", UI_BG:"rgb(28,28,34)", UI_DARK:"rgb(8,8,12)", UI_BUTTON:"rgb(72,72,82)",
  UI_HOVER:"rgb(103,103,116)"
};
const ORES = {
  stone:{value:1,hp:1,color:C.STONE,need:1}, coal:{value:2,hp:2,color:"rgb(35,35,38)",need:1},
  copper:{value:3,hp:3,color:"rgb(184,102,52)",need:2}, iron:{value:5,hp:4,color:"rgb(170,170,180)",need:3},
  silver:{value:8,hp:5,color:"rgb(215,220,235)",need:4}, gold:{value:12,hp:6,color:C.GOLD,need:5},
  ruby:{value:18,hp:8,color:C.RED,need:6}, sapphire:{value:24,hp:9,color:C.BLUE,need:7},
  emerald:{value:32,hp:10,color:C.GREEN,need:8}, void_crystal:{value:45,hp:13,color:C.PURPLE,need:10}
};
const SHOP_ITEMS = [
  {name:"Copper Pick",cost:60,kind:"pick",power:2,desc:"Mine harder ores."},
  {name:"Iron Pick",cost:180,kind:"pick",power:4,desc:"Break stone faster."},
  {name:"Steel Pick",cost:330,kind:"pick",power:5,desc:"A stronger mining pick."},
  {name:"Crystal Pick",cost:520,kind:"pick",power:7,desc:"Bite through deep crystals."},
  {name:"Diamond Pick",cost:900,kind:"pick",power:10,desc:"Smash rich deep ore."},
  {name:"Void Pick",cost:1500,kind:"pick",power:14,desc:"Cuts through void crystal."},
  {name:"Titan Pick",cost:2400,kind:"pick",power:20,desc:"A huge late-game pick."},
  {name:"Mega Satchel",cost:220,kind:"bag",power:35,desc:"Carry more ore."},
  {name:"Huge Satchel",cost:500,kind:"bag",power:60,desc:"Carry a lot more ore."},
  {name:"Giant Satchel",cost:950,kind:"bag",power:100,desc:"Carry a giant load."},
  {name:"Cavern Pack",cost:1600,kind:"bag",power:160,desc:"Huge mining capacity."},
  {name:"Mega Cave Bag",cost:2600,kind:"bag",power:250,desc:"Almost never fills."},
  {name:"Endless Satchel",cost:4200,kind:"bag",power:400,desc:"Massive ore storage."}
];
const DECOR = [
  {name:"Sofa",cost:240,kind:"sofa",desc:"A soft pink sofa."}, {name:"Table",cost:120,kind:"table",desc:"A small wooden table."},
  {name:"Pink Rug",cost:80,kind:"rug",desc:"A soft pink floor rug."}, {name:"Plant",cost:100,kind:"plant",desc:"A leafy cave plant."},
  {name:"Lamp",cost:150,kind:"lamp",desc:"A warm yellow lamp."}, {name:"Bed",cost:220,kind:"bed",desc:"A cozy mole bed."},
  {name:"Bookshelf",cost:190,kind:"bookshelf",desc:"A wooden bookshelf."}, {name:"TV",cost:260,kind:"tv",desc:"A little cave TV."},
  {name:"Fish Tank",cost:240,kind:"tank",desc:"A fish tank."}, {name:"Poster",cost:70,kind:"poster",desc:"A mole poster."},
  {name:"Mushroom",cost:90,kind:"mushroom",desc:"A red mushroom."}
];
const FOODS = {
  worms:{label:"Worms",energy:45,value:5,desc:"Small cave snack. Gives much more energy than before."},
  mushroom:{label:"Cave Mushrooms",energy:75,value:8,desc:"Found while mining. Good energy boost."},
  fish:{label:"Fish",energy:130,value:18,desc:"Best normal energy food. Fish gives the most."},
  golden_fish:{label:"Golden Fish",energy:220,value:60,desc:"Rare fishing catch. Almost fills your energy."}
};
let buttons = [];
let lastTime = performance.now();
let autosaveTimer = 0;
let soundOn = true;

function blankInv(){ const inv={}; Object.keys(ORES).forEach(k=>inv[k]=0); return inv; }
function blankMarket(){ const m={}; Object.keys(ORES).forEach(k=>m[k]=1.0); return m; }
function blankFoods(){ return {worms:0,mushroom:0,fish:0,golden_fish:0}; }
function blankDecor(){ const d={}; DECOR.forEach(x=>d[x.name]=false); return d; }
function defaultPlayer(){
  return {x:12,y:9,px:12*TILE+16,py:9*TILE+16,hp:100,maxHp:100,gold:80,pick:1,bag:30,floor:0,
    energy:300,maxEnergy:300,inv:blankInv(),foods:{worms:3,mushroom:0,fish:1,golden_fish:0},eggs:[],pets:[],
    mined:blankInv(),hat:"Miner Hat",ownedHats:["Miner Hat"],facing:1,path:[],pending:null,houseDecor:blankDecor()};
}
let game = {
  state:"title", mode:"town", day:1, market:blankMarket(), messages:["Welcome to Mole Mine Rocks!"], map:[], player:defaultPlayer(), selectedShop:0,
  inventoryTab:"Ores", shopTab:"Tools", houseTick:0, started:false
};
function msg(t){ game.messages.unshift(t); game.messages = game.messages.slice(0,9); }
function saveGame(){
  try{ localStorage.setItem(SAVE_KEY, JSON.stringify({day:game.day,market:game.market,player:game.player})); localStorage.setItem(STARTED_KEY,"yes"); }catch(e){}
}
function loadGame(){
  const started = localStorage.getItem(STARTED_KEY)==="yes";
  game.started = started;
  if(started){
    const raw = localStorage.getItem(SAVE_KEY);
    if(raw){
      try{
        const s = JSON.parse(raw);
        game.day = s.day || 1; game.market = Object.assign(blankMarket(), s.market || {});
        game.player = Object.assign(defaultPlayer(), s.player || {});
        game.player.inv = Object.assign(blankInv(), game.player.inv || {});
        game.player.mined = Object.assign(blankInv(), game.player.mined || {});
        game.player.foods = Object.assign(blankFoods(), game.player.foods || {});
        game.player.houseDecor = Object.assign(blankDecor(), game.player.houseDecor || {});
        game.player.maxEnergy = 300;
        game.player.energy = Math.min(300, Number(game.player.energy ?? 300));
        game.player.path = []; game.player.pending = null;
      }catch(e){ game.player = defaultPlayer(); }
    }
  }
  generateTown(true);
  updateStartPanel();
}
function updateStartPanel(){
  const started = localStorage.getItem(STARTED_KEY)==="yes";
  const title = document.getElementById("startTitle");
  const text = document.getElementById("startText");
  const btn = document.getElementById("startGameBtn");
  if(started){ title.textContent = "SAVED GAME"; text.textContent = "Your save was found in browser local data. Press Play Saved Game to continue; the site will not ask for New Game again."; btn.textContent = "PLAY SAVED GAME"; }
  else { title.textContent = "NEW GAME"; text.textContent = "Press New Game once. After that, Mole Mine Rocks saves into this browser's local data and will never ask for New Game again."; btn.textContent = "NEW GAME"; }
}
function startGame(){
  if(localStorage.getItem(STARTED_KEY)!=="yes"){
    game.player = defaultPlayer(); game.day = 1; game.market = blankMarket(); game.messages=["New game started."]; localStorage.setItem(STARTED_KEY,"yes");
  } else { msg("Loaded saved game."); }
  game.state = "game"; generateTown(true); saveGame(); updateStartPanel(); canvas.focus(); beep("start");
}
function newMarket(){ game.day++; Object.keys(game.market).forEach(k=>game.market[k]=Math.round((0.65+Math.random()*1.1)*100)/100); msg("Day "+game.day+": market prices shifted."); }

function tile(kind,hp=1){ return {kind,hp}; }
function generateTown(first=false){
  game.mode="town"; game.player.floor=0; game.map=[];
  for(let y=0;y<MAP_H;y++){ const row=[]; for(let x=0;x<MAP_W;x++){
    let k="grass"; if(x===0||x===MAP_W-1||y===0||y===MAP_H-1) k="fence"; else if(Math.random()<0.04) k="flower";
    row.push(tile(k));
  } game.map.push(row); }
  for(let x=2;x<23;x++) game.map[9][x]=tile("path");
  for(let y=2;y<15;y++) game.map[y][12]=tile("path");
  game.map[9][22]=tile("mine"); game.map[6][7]=tile("shop"); game.map[6][17]=tile("house"); game.map[11][17]=tile("market");
  for(let x=3;x<=6;x++){ game.map[13][x]=tile("pond"); game.map[14][x]=tile("pond"); }
  game.player.x=12; game.player.y=9; snap(); game.player.path=[]; game.player.pending=null;
  if(!first) newMarket();
}
function orePool(){
  const f=game.player.floor; let p=["stone","coal"];
  if(f>=2)p.push("copper","iron"); if(f>=3)p.push("silver"); if(f>=4)p.push("gold","ruby"); if(f>=6)p.push("sapphire","emerald"); if(f>=7)p.push("void_crystal"); return p;
}
function generateMine(floor){
  game.mode="mine"; game.player.floor=floor || game.player.floor+1; game.map=[];
  for(let y=0;y<MAP_H;y++){ const row=[]; for(let x=0;x<MAP_W;x++) row.push(tile("wall")); game.map.push(row); }
  const rooms=[];
  for(let i=0;i<8;i++){
    const w=4+randInt(4), h=3+randInt(3), x=1+randInt(MAP_W-w-2), y=1+randInt(MAP_H-h-2);
    rooms.push({x,y,w,h});
    for(let yy=y;yy<y+h;yy++) for(let xx=x;xx<x+w;xx++) game.map[yy][xx]=tile("floor");
  }
  for(let i=0;i<rooms.length-1;i++){
    const a=rooms[i], b=rooms[i+1], cx1=a.x+(a.w/2|0), cy1=a.y+(a.h/2|0), cx2=b.x+(b.w/2|0), cy2=b.y+(b.h/2|0);
    for(let x=Math.min(cx1,cx2);x<=Math.max(cx1,cx2);x++) game.map[cy1][x]=tile("floor");
    for(let y=Math.min(cy1,cy2);y<=Math.max(cy1,cy2);y++) game.map[y][cx2]=tile("floor");
  }
  const pool=orePool();
  for(let y=1;y<MAP_H-1;y++) for(let x=1;x<MAP_W-1;x++){
    if(game.map[y][x].kind==="wall" && Math.random()<0.38){ const o=choice(pool); game.map[y][x]=tile(o,ORES[o].hp); }
    else if(game.map[y][x].kind==="floor" && Math.random()<0.035){ const o=choice(pool); game.map[y][x]=tile(o,ORES[o].hp); }
  }
  const s=rooms[0], e=rooms[rooms.length-1]; const sx=s.x+1, sy=s.y+1, ex=e.x+e.w-2, ey=e.y+e.h-2;
  game.map[sy][sx]=tile("up"); game.map[ey][ex]=tile("down"); game.player.x=sx; game.player.y=sy; snap(); game.player.path=[]; game.player.pending=null;
  msg("Entered mine floor "+game.player.floor+"."); beep("stairs");
}
function randInt(n){ return Math.floor(Math.random()*n); } function choice(a){ return a[randInt(a.length)]; }
function snap(){ game.player.px=game.player.x*TILE+16; game.player.py=game.player.y*TILE+16; }
function getTile(x,y){ if(x>=0&&x<MAP_W&&y>=0&&y<MAP_H) return game.map[y][x]; return tile("void"); }
function passable(x,y){ return ["floor","grass","path","flower","up","down","mine","shop","house","market"].includes(getTile(x,y).kind); }
function neighbors(c){ const [x,y]=c, out=[]; [[1,0],[-1,0],[0,1],[0,-1]].forEach(d=>{const nx=x+d[0],ny=y+d[1]; if(nx>=0&&ny>=0&&nx<MAP_W&&ny<MAP_H&&passable(nx,ny)) out.push([nx,ny]);}); return out; }
function findPath(start,goal){
  if(!passable(goal[0],goal[1])) return [];
  const q=[start], came={[start.join(',')]:null}, seen=new Set([start.join(',')]);
  while(q.length){
    q.sort((a,b)=>(Math.abs(goal[0]-a[0])+Math.abs(goal[1]-a[1]))-(Math.abs(goal[0]-b[0])+Math.abs(goal[1]-b[1])));
    const cur=q.shift(); if(cur[0]===goal[0]&&cur[1]===goal[1]) break;
    for(const n of neighbors(cur)){ const k=n.join(','); if(!seen.has(k)){ seen.add(k); came[k]=cur; q.push(n); } }
  }
  if(!(goal.join(',') in came)) return [];
  const path=[]; let cur=goal; while(cur && !(cur[0]===start[0]&&cur[1]===start[1])){ path.unshift(cur); cur=came[cur.join(',')]; } return path;
}
function adjacentFor(target){
  const [tx,ty]=target, opts=[[tx,ty-1],[tx+1,ty],[tx,ty+1],[tx-1,ty]].filter(c=>passable(c[0],c[1]));
  let best=null, bestPath=null, start=[game.player.x,game.player.y];
  for(const c of opts){ const path=(c[0]===start[0]&&c[1]===start[1])?[]:findPath(start,c); if(path.length|| (c[0]===start[0]&&c[1]===start[1])){ if(bestPath===null||path.length<bestPath.length){ best=c; bestPath=path; } } }
  return best;
}
function setPath(dest,action){
  const start=[game.player.x,game.player.y];
  if(dest[0]===start[0]&&dest[1]===start[1]){ game.player.path=[]; game.player.pending=action; finishAction(); return; }
  const p=findPath(start,dest); if(p.length){ game.player.path=p; game.player.pending=action; beep("move"); } else { msg("No path there."); beep("error"); }
}
function updateMovement(dt){
  const p=game.player; if(!p.path.length) return; const [tx,ty]=p.path[0]; const targetX=tx*TILE+16, targetY=ty*TILE+16;
  const dx=targetX-p.px, dy=targetY-p.py, dist=Math.hypot(dx,dy), speed=190;
  if(dist<=speed*dt){ p.px=targetX; p.py=targetY; p.x=tx; p.y=ty; p.path.shift(); if(!p.path.length) finishAction(); }
  else { if(Math.abs(dx)>0.1) p.facing=dx>0?1:-1; p.px += dx/dist*speed*dt; p.py += dy/dist*speed*dt; }
}
function finishAction(){ const a=game.player.pending; game.player.pending=null; if(!a)return; const [x,y]=a.pos||[game.player.x,game.player.y];
  if(a.kind==="mine") generateMine(1); else if(a.kind==="shop") game.state="shop"; else if(a.kind==="house") game.state="house"; else if(a.kind==="market") game.state="market";
  else if(a.kind==="ore") mineTile(x,y); else if(a.kind==="up") generateTown(); else if(a.kind==="down") generateMine(game.player.floor+1); else if(a.kind==="fish") catchFish();
}
function clickMap(mx,my){ if(game.state!=="game") return; if(mx>=PANEL_X || my>=MAP_H*TILE) return; const gx=Math.floor(mx/TILE), gy=Math.floor(my/TILE), k=getTile(gx,gy).kind;
  if(ORES[k]){ const stand=adjacentFor([gx,gy]); stand?setPath(stand,{kind:"ore",pos:[gx,gy]}):msg("Cannot reach that ore."); }
  else if(k==="mine"&&game.mode==="town") setPath([gx,gy],{kind:"mine",pos:[gx,gy]});
  else if(k==="shop"&&game.mode==="town") setPath([gx,gy],{kind:"shop",pos:[gx,gy]});
  else if(k==="house"&&game.mode==="town") setPath([gx,gy],{kind:"house",pos:[gx,gy]});
  else if(k==="market"&&game.mode==="town") setPath([gx,gy],{kind:"market",pos:[gx,gy]});
  else if(k==="pond"&&game.mode==="town"){ const stand=adjacentFor([gx,gy]); stand?setPath(stand,{kind:"fish",pos:[gx,gy]}):msg("Stand near the pond to fish."); }
  else if(k==="up"&&game.mode==="mine") setPath([gx,gy],{kind:"up",pos:[gx,gy]});
  else if(k==="down"&&game.mode==="mine") setPath([gx,gy],{kind:"down",pos:[gx,gy]});
  else if(passable(gx,gy)) setPath([gx,gy],null); else { msg("Click a walkable tile, ore, market, pond, or stairs."); beep("error"); }
}
function moveKey(dx,dy){ const nx=game.player.x+dx, ny=game.player.y+dy; if(dx!==0) game.player.facing=dx>0?1:-1; if(passable(nx,ny)){ game.player.x=nx; game.player.y=ny; snap(); game.player.path=[]; beep("step"); } else if(ORES[getTile(nx,ny).kind]) mineTile(nx,ny); }
function carry(){ return Object.values(game.player.inv).reduce((a,b)=>a+Number(b||0),0); }
function mineTile(x,y){ const p=game.player, t=getTile(x,y), kind=t.kind; if(!ORES[kind]){msg("Nothing to mine there.");return;}
  if(p.energy<2){ msg("Too tired. Eat fish, worms, or wait for slow recharge."); beep("error"); return; }
  if(p.pick < ORES[kind].need){ msg("Need pick power "+ORES[kind].need+" for "+kind+"."); beep("error"); return; }
  if(carry()>=p.bag){ msg("Bag full. Sell at Market."); beep("error"); return; }
  p.energy=Math.max(0,p.energy-2); t.hp -= p.pick; beep("mine");
  if(t.hp<=0){ p.inv[kind]=(p.inv[kind]||0)+1; p.mined[kind]=(p.mined[kind]||0)+1; game.map[y][x]=tile("floor"); msg("Mined "+kind+"."); lootDrops(); }
  else msg("Cracked "+kind+" ("+t.hp+" hp left)."); saveGame();
}
function lootDrops(){ const f=game.player.floor;
  if(Math.random()<0.08){ game.player.foods.worms++; msg("Found a worm snack."); beep("drop"); }
  if(f>=2 && Math.random()<0.04){ game.player.foods.mushroom++; msg("Found a cave mushroom."); beep("drop"); }
  if(f>=5 && Math.random()<0.025){ game.player.eggs.push({pet:"Snake",name:"Snake Egg"}); msg("Rare drop: Snake Egg!"); beep("egg"); }
  if(f>=8 && Math.random()<0.015){ game.player.eggs.push({pet:"Dragon",name:"Dragon Egg"}); msg("Rare drop: Dragon Egg!"); beep("egg"); }
  if(f>=10 && Math.random()<0.010){ game.player.eggs.push({pet:"Horse",name:"Horse Egg"}); msg("Ultra rare drop: Horse Egg!"); beep("egg"); }
  if(Math.random()<0.04){ const g=5+game.player.floor*3; game.player.gold+=g; msg("Found loose gold +"+g+"!"); }
}
function catchFish(){ const p=game.player; if(p.energy<8){ msg("Too tired to fish. Wait or eat food."); beep("error"); return; }
  p.energy=Math.max(0,p.energy-8); if(Math.random()<0.08){ p.foods.golden_fish++; msg("Caught a GOLDEN FISH!"); beep("egg"); } else { p.foods.fish++; msg("Caught a fish."); beep("fish"); } saveGame();
}
function action(){ const p=game.player, here=getTile(p.x,p.y).kind;
  if(game.mode==="town"&&here==="mine") return generateMine(1); if(game.mode==="town"&&here==="shop") return game.state="shop"; if(game.mode==="town"&&here==="house") return game.state="house"; if(game.mode==="town"&&here==="market") return game.state="market";
  if(game.mode==="mine"&&here==="up") return generateTown(); if(game.mode==="mine"&&here==="down") return generateMine(p.floor+1);
  for(const d of [[0,-1],[1,0],[0,1],[-1,0]]){ const x=p.x+d[0], y=p.y+d[1]; if(ORES[getTile(x,y).kind]) return mineTile(x,y); if(getTile(x,y).kind==="pond") return catchFish(); }
  msg("Nothing nearby to use."); beep("error");
}
function eat(food){ const p=game.player, item=FOODS[food]; if(!item||!p.foods[food]){msg("No "+(item?item.label:food)+" to eat.");beep("error");return;}
  p.foods[food]--; p.energy=Math.min(300,p.energy+item.energy); msg("Ate "+item.label+" for +"+item.energy+" energy."); beep("eat"); saveGame();
}
function hatchAll(){ const eggs=game.player.eggs.splice(0); if(!eggs.length){msg("No eggs to hatch.");beep("error");return;}
  eggs.forEach(e=>{ const pet=e.pet||"Pet", stats={power:40+randInt(61),speed:40+randInt(61),luck:40+randInt(61),heart:40+randInt(61)}; if(pet==="Horse") Object.keys(stats).forEach(k=>stats[k]+=35+randInt(41)); game.player.pets.push({name:pet,stats,nature:choice(["Normal","Sparkly","Ancient","Mythic"])}); });
  msg("Hatched "+eggs.length+" egg(s)."); beep("hatch"); saveGame();
}
function petValue(pet){ const total=Object.values(pet.stats||{}).reduce((a,b)=>a+Number(b||0),0); let base=25; if(pet.name.includes("Snake")) base=95; else if(pet.name.includes("Dragon")) base=120; else if(pet.name.includes("Horse")) base=180; if(pet.name.includes("Horse")&&total>=300) base=950; else if(pet.name.includes("Horse")&&total>=240) base=650; else if(total>=300) base+=220; else if(total>=240) base+=110; if(["Mythic","Ancient","Sparkly"].includes(pet.nature)) base+=90; return base|0; }
function eggValue(e){ const p=e.pet||e.name||""; if(p.includes("Horse")) return 220; if(p.includes("Dragon")) return 120; if(p.includes("Snake")) return 95; return 25; }
function sellOre(){ let total=0; Object.keys(game.player.inv).forEach(o=>{ const n=game.player.inv[o]||0; total+=Math.floor(ORES[o].value*(game.market[o]||1))*n; game.player.inv[o]=0; }); game.player.gold+=total; msg("Sold ore for "+total+" gold."); if(total>0){newMarket(); beep("sell");} saveGame(); }
function sellFoods(){ let total=0; Object.keys(FOODS).forEach(f=>{ const n=game.player.foods[f]||0; total+=FOODS[f].value*n; game.player.foods[f]=0; }); game.player.gold+=total; msg("Sold foods for "+total+" gold."); if(total>0)beep("sell"); saveGame(); }
function sellEggs(){ const total=game.player.eggs.reduce((a,e)=>a+eggValue(e),0); game.player.eggs=[]; game.player.gold+=total; msg("Sold eggs for "+total+" gold."); if(total>0)beep("sell"); saveGame(); }
function sellPets(){ const total=game.player.pets.reduce((a,p)=>a+petValue(p),0); game.player.pets=[]; game.player.gold+=total; msg("Sold hatched pets for "+total+" gold."); if(total>0)beep("sell"); saveGame(); }
function sellEverything(){ sellOre(); sellFoods(); sellEggs(); sellPets(); msg("Market bought everything collectable."); saveGame(); }
function buyShop(i){ const it=SHOP_ITEMS[i], p=game.player; if(!it)return; if(p.gold<it.cost){ msg("Not enough gold."); beep("error"); return; } p.gold-=it.cost; if(it.kind==="pick") p.pick=Math.max(p.pick,it.power); else p.bag=Math.max(p.bag,it.power); msg("Bought "+it.name+"."); beep("buy"); saveGame(); }
function buyDecor(i){ const it=DECOR[i], p=game.player; if(!it)return; if(p.houseDecor[it.name]){ msg("Already own "+it.name+"."); return; } if(p.gold<it.cost){ msg("Not enough gold."); beep("error"); return; } p.gold-=it.cost; p.houseDecor[it.name]=true; msg("Bought "+it.name+"."); beep("buy"); saveGame(); }
