// Sound effects: generated with WebAudio so the HTML has lots of sounds without external files.
let audioCtx=null;
function activateAudio(){ if(!audioCtx) audioCtx = new (window.AudioContext||window.webkitAudioContext)(); }
function beep(kind){ if(!soundOn) return; try{ activateAudio(); const t=audioCtx.currentTime; const seq={click:[[620,.04,"square"]],move:[[220,.03,"triangle"]],step:[[180,.025,"triangle"]],mine:[[90,.05,"square"],[130,.04,"square"]],drop:[[880,.05,"sine"],[1220,.06,"sine"]],egg:[[540,.08,"triangle"],[760,.10,"triangle"],[980,.12,"triangle"]],sell:[[330,.06,"square"],[660,.08,"square"]],buy:[[420,.05,"sine"],[840,.08,"sine"]],eat:[[240,.06,"triangle"],[360,.06,"triangle"]],fish:[[250,.05,"sine"],[500,.1,"sine"]],hatch:[[450,.08,"sine"],[900,.12,"sine"]],error:[[90,.15,"sawtooth"]],stairs:[[180,.08,"square"],[120,.08,"square"]],save:[[700,.05,"sine"],[900,.05,"sine"]],page:[[300,.04,"triangle"],[450,.04,"triangle"]],start:[[260,.06,"square"],[520,.08,"square"],[780,.12,"square"]]}; (seq[kind]||seq.click).forEach((n,i)=>tone(n[0],n[1],n[2],t+i*.055)); }catch(e){} }
function tone(freq,dur,type,start){ const o=audioCtx.createOscillator(), g=audioCtx.createGain(); o.type=type; o.frequency.value=freq; g.gain.setValueAtTime(0.0001,start); g.gain.exponentialRampToValueAtTime(.12,start+.01); g.gain.exponentialRampToValueAtTime(.0001,start+dur); o.connect(g); g.connect(audioCtx.destination); o.start(start); o.stop(start+dur+.02); }

function loop(now){ const dt=Math.min(.05,(now-lastTime)/1000); lastTime=now; if(game.state!=="title"){ game.player.energy=Math.min(300,game.player.energy+dt*0.125); updateMovement(dt); autosaveTimer+=dt; if(autosaveTimer>5){autosaveTimer=0;saveGame();} } draw(); requestAnimationFrame(loop); }

